PORT=3001
JWT_SECRET=change-this-to-a-long-random-secret-in-production
CLIENT_URL=http://localhost:3001
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project.supabase.co:5432/postgres

# Metered.ca TURN server (for voice/video calls)
# Get API key from: https://www.metered.ca/ → Developers
# Domain is your subdomain, e.g. dilnukavsis.metered.live
METERED_API_KEY=your-metered-api-key
METERED_DOMAIN=your-subdomain.metered.live

# Doora AI assistant (NVIDIA API — server-side only, never expose in frontend)
# Get API key from: https://build.nvidia.com/
NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
